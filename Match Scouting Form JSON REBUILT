    "type": "derived",
    "formula": "autoTotalFuel + 15*AutoClimb",
    "id": "AutoPoints"
  },
  {
    "type": "derived",
    "formula": "SingleFuel + 5*SetsOfFuel",
    "id": "TeleopPoints"
  },
  {
    "type": "derived",
    "formula": " multiselect(ClimbHeight, '0', 0, '1', 10, '2', 20, '3',30)",
    "id": "EndgamePoints"
  },
  {
    "type": "derived",
    "formula": "AutoPoints + TeleopPoints + EndgamePoints",
    "id": "contributedPoints"
  },
  {
    "type": "derived",
    "formula": "SingleFuel + 5*SetsOfFuel + autoTotalFuel",
    "id": "FuelPoints"
  },
  {
    "type": "derived",
    "formula": "multiselect(ClimbHeight, '0', 0, '1', 10, '2', 20, '3',30) + 15*AutoClimb",
    "id": "ClimbPoints"
  },
  {
    "type": "derived",
    "formula": "if(autoTotalFuel > (SingleFuel + 5*SetsOfFuel), 1, 0)",
    "id": "AutoMistake"
  }
